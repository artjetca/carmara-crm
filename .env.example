# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Maps API
# Frontend map embeds may read VITE_GOOGLE_MAPS_API_KEY.
# Netlify backend functions such as Auto captar must use a server-side key:
# prefer GOOGLE_PLACES_API_KEY, fallback GOOGLE_MAPS_SERVER_API_KEY, then GOOGLE_MAPS_API_KEY.
# Do not use a browser key with referer restrictions for backend Google Places calls.
# After changing Netlify environment variables, redeploy the site.
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_MAPS_SERVER_API_KEY=your-server-side-google-maps-api-key
GOOGLE_PLACES_API_KEY=your-server-side-google-places-api-key

# Map provider switch: 'google' (default) or 'leaflet'
VITE_MAP_PROVIDER=google
